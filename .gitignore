# ========================
# Godot 4 Specific
# ========================
# Ignores the massive imported resource cache
.godot/
# Ignores user-specific export configurations (optional, but standard)
export_presets.cfg

# ========================
# SCons Build System
# ========================
# SCons cache file
.sconsign.dblite

# ========================
# C++ Compilation & MSVC
# ========================
# Object files (compiled unlinked code)
*.obj
*.o
# Debug symbol files (these get HUGE, usually hundreds of megabytes)
*.pdb
*.ilk
# Export and static library files
*.exp
*.lib
~*.dll

# ========================
# Godot-CPP Auto-Generated
# ========================
# Even if it's a submodule, we want to ensure we don't accidentally stage these
godot-cpp/bin/
godot-cpp/gen/

# ========================
# OS Specific
# ========================
.DS_Store
Thumbs.db